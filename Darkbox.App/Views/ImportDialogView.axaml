<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Darkbox.ViewModels"
             x:Class="Darkbox.Views.ImportDialogView"
             x:DataType="vm:ImportDialogViewModel">
    <Grid>
        <Rectangle Fill="#56000000"/>
        <Border Background="#1E1E1E"
                CornerRadius="8"
                Margin="64">
            <Grid ColumnDefinitions="250, *, 300" Margin="16">
                <Grid Grid.Column="0" RowDefinitions="Auto, *">
                    <TextBlock Classes="xl"
                               Grid.Row="0"
                               Text="Locations"
                               Margin="0, 0, 0 16"/>
                    <TreeView Grid.Row="1" ItemsSource="{Binding Drives}"
                              SelectedItem="{Binding SelectedFolder}">
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem" x:DataType="vm:FileSystemItemViewModel">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            </Style>
                        </TreeView.Styles>
                        
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Subfolders}">
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
                <Grid Grid.Column="1">
                    <Border Background="#121212"
                            Margin="0 0"
                            CornerRadius="7"></Border>
                </Grid>
                <Grid Grid.Column="2" RowDefinitions="*, 50, 50">
                    <StackPanel Grid.Row="0"
                                Orientation="Vertical">
                        <Border Background="#E0E0E0"
                                Margin="20 0 0 0"
                                Height="200">
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>